TZ=Asia/Shanghai

# New API
POSTGRES_USER=newapi
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=new-api
NEWAPI_SESSION_SECRET=change-me-session-secret
NEWAPI_CRYPTO_SECRET=change-me-crypto-secret
NEWAPI_HOST_PORT=127.0.0.1:3000

# CPA / CLIProxyAPI
CPA_HOST_PORT=127.0.0.1:8317
CPA_API_KEY=sk-change-me-cpa-api-key
CPA_MANAGEMENT_KEY=change-me-cpa-management-key
CPA_MANAGEMENT_SECRET_HASH=change-me-bcrypt-hash

# CPA Usage Keeper
USAGE_KEEPER_HOST_PORT=127.0.0.1:8320
USAGE_API_KEY=change-me-usage-api-key

# Optional Grok2API local fork
GROK2API_HOST_PORT=127.0.0.1:8001
GROK2API_STORAGE_MODE=file
GROK2API_WORKERS=1
GROK2API_LOG_LEVEL=INFO

# Optional upstream proxy used for a Cloudflare-sensitive OpenAI-compatible upstream.
EZOUAPI_UPSTREAM_HOST=sub2api.htao.ltd
EZOUAPI_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/125 Safari/537.36
